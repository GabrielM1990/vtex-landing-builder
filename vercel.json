{
  "version": 2,
  "builds": [
    {
      "src": "backend/package.json",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json", 
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run vercel-build",
        "installCommand": "npm run install:all",
        "outputDirectory": "frontend/dist",
        "framework": "vite",
        "rewrites": [
          {
            "source": "/(.*)",
            "destination": "/"
          }
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
